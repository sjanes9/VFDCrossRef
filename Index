}

async function parsePDFFile(drive, file) {
  if (typeof pdfjsLib === 'undefined') {
    setStatus(drive, '✗ PDF.js not loaded — please use a .txt or .csv export instead', 'err');
    return;
  }
  const arrayBuffer = await file.arrayBuffer();
  let pdfDoc;
  try {
    pdfDoc = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
  } catch(e) {
    setStatus(drive, '✗ Could not open PDF: ' + e.message, 'err');
    return;
  }
  const params = new Map();
  const preview = [];
  for (let pageNum = 1; pageNum <= pdfDoc.numPages; pageNum++) {
    const page    = await pdfDoc.getPage(pageNum);
    const content = await page.getTextContent();
    const viewport = page.getViewport({ scale: 1.0 });
    const pageH    = viewport.height;
    // Tokens with x-coordinates (PDF.js: x = transform[4], width = item.width)
    const toks = content.items.map(item => ({
      text: (item.str || '').trim(),
      x0: item.transform[4],
      x1: item.transform[4] + (item.width || 0),
      y: pageH - item.transform[5],
    })).filter(t => t.text !== '');

    const rowMap = new Map();
    for (const t of toks) {
      const bucket = Math.round(t.y / 2) * 2;
      if (!rowMap.has(bucket)) rowMap.set(bucket, []);
      rowMap.get(bucket).push(t);
    }
    const orderedRows = [...rowMap.entries()].sort((a,b) => a[0]-b[0]).map(e => e[1]);

    // Gap-cluster a row's tokens (sorted by x) into cells, so multi-word names
    // and multi-word values ("Ramp, CF", "60 Seconds") stay intact.
    const clusterRow = rowItems => {
      const sorted = rowItems.slice().sort((a,b) => a.x0 - b.x0);
      const cells = [];
      let cur = null;
      for (const t of sorted) {
        if (cur && t.x0 - cur.x1 > 22) { cells.push(cur); cur = null; }
        if (!cur) cur = { text: t.text, x0: t.x0, x1: t.x1 };
        else { cur.text += ' ' + t.text; cur.x1 = t.x1; }
      }
      if (cur) cells.push(cur);
      return cells;
    };

    // Detect column x-boundaries from the header row
    // ("Port # Name Value Units Default Min Max"). Falls back to a validated
    // default layout so the parser works even if a header isn't found.
    const HDR = { 'port':'port','#':'num','name':'name','value':'value','units':'unit','default':'dflt','min':'min','max':'max' };
    let colOrder = ['port','num','name','value','unit','dflt','min','max'];
    let colBound = { port:0, num:60, name:114, value:203, unit:296, dflt:359, min:425, max:502 };
    for (const rowItems of orderedRows) {
      const found = {};
      for (const c of clusterRow(rowItems)) {
        const k = c.text.trim().toLowerCase();
        if (HDR[k] !== undefined) found[HDR[k]] = c.x0;
      }
      if (found.name !== undefined && found.value !== undefined && Object.keys(found).length >= 6) {
        const order = Object.keys(found).sort((a,b) => found[a] - found[b]);
        const b = {};
        order.forEach((col, i) => { b[col] = (i === 0) ? 0 : (found[order[i-1]] + found[col]) / 2; });
        colOrder = order; colBound = b;
        break;
      }
    }
    const assignCol = x => {
      let chosen = colOrder[0];
      for (const c of colOrder) { if (x >= colBound[c]) chosen = c; }
      return chosen;
    };

    for (const rowItems of orderedRows) {
      const row = {};
      for (const c of clusterRow(rowItems)) {
        const col = assignCol(c.x0);
        row[col] = row[col] ? (row[col] + ' ' + c.text) : c.text;
      }
      const port = parseInt(row.port, 10);
      const num  = parseInt(row.num, 10);
      if (isNaN(port) || isNaN(num) || num < 0 || num > 99999) continue;
      const name = (row.name || '').trim();
      if (!name || name.length < 2 || params.has(num)) continue;
      const entry = { num, name, value: (row.value || '').trim() };
      if (row.unit) entry.unit = row.unit.trim();
      if (row.dflt) entry.dflt = row.dflt.trim();
      if (row.min !== undefined && row.min !== '') entry.min = String(row.min).trim();
      if (row.max !== undefined && row.max !== '') entry.max = String(row.max).trim();
      params.set(num, entry);
      if (preview.length < 5) preview.push([String(port), String(num), name, entry.value, entry.unit || '', entry.dflt || '']);
    }
  }
  if (params.size === 0) {
    setStatus(drive, '✗ No parameters found in PDF — check file is a CCW parameter export', 'err');
    if (drive === 'A') parsedA = null; else parsedB = null;
  } else {
    setStatus(drive, '✓ Loaded ' + params.size + ' parameters from "' + file.name + '"', 'ok');
    hideEncodingPicker(drive);
    if (drive === 'A') parsedA = params; else parsedB = params;
    const nameEl = document.getElementById('name'+drive);
    if (nameEl && (nameEl.value === 'Drive '+drive || nameEl.value === '')) {
      nameEl.value = file.name.replace(/\.[^.]+$/, '').replace(/[_-]/g,' ');
    }
    const previewEl = document.getElementById('preview'+drive);
    if (previewEl) showPreviewEl(previewEl, preview);
  }
  document.getElementById('compareBtn').disabled = !(parsedA && parsedB);
}

function detectEncoding(buf) {
  const b = new Uint8Array(buf);
  if (b[0]===0xFF && b[1]===0xFE) return 'utf-16le';
  if (b[0]===0xFE && b[1]===0xFF) return 'utf-16be';
  if (b[0]===0xEF && b[1]===0xBB && b[2]===0xBF) return 'utf-8';
  let validSeq=0, rawHigh=0;
  for (let i=0; i<Math.min(b.length,4000); i++) {
    if (b[i]>0x7F) {
      if ((b[i]&0xE0)===0xC0 && i+1<b.length && (b[i+1]&0xC0)===0x80) { validSeq++; i++; }
      else if ((b[i]&0xF0)===0xE0 && i+2<b.length) { validSeq++; i+=2; }
      else rawHigh++;
    }
  }
  return (rawHigh > validSeq*2 && rawHigh > 5) ? 'windows-1252' : 'utf-8';
}
function decodeBuffer(buf, encoding) {
  let text = new TextDecoder(encoding, { fatal: false }).decode(buf);
  if (text.charCodeAt(0) === 0xFEFF) text = text.slice(1);
  text = text.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '');
  return text;
}
function decodeAndParse(drive, encoding, filename) {
  const buf = window['_rawBuf_'+drive];
  if (!buf) return;
  const encSel = document.getElementById('enc'+drive);
  if (encSel) encSel.value = encoding;
  const text   = decodeBuffer(buf, encoding);
  const result = parseTextParams(text);
  const previewEl = document.getElementById('preview'+drive);
  if (result.error) {
    setStatus(drive, '✗ ' + result.error, 'err');
    showEncodingPicker(drive);
    if (previewEl) previewEl.style.display='none';
    if (drive === 'A') parsedA = null; else parsedB = null;
  } else {
    const clean = isPreviewClean(result.preview);
    if (!clean) {
      setStatus(drive, '⚠ Text looks garbled — try a different encoding below', 'err');
      showEncodingPicker(drive);
    } else {
      setStatus(drive, '✓ Loaded ' + result.params.size + ' parameters from "' + filename + '"', 'ok');
      hideEncodingPicker(drive);
    }
    if (drive === 'A') parsedA = result.params; else parsedB = result.params;
    const nameEl = document.getElementById('name'+drive);
    if (nameEl && (nameEl.value === 'Drive '+drive || nameEl.value === '')) {
      nameEl.value = filename.replace(/\.[^.]+$/, '').replace(/[_-]/g,' ');
    }
    if (previewEl) showPreviewEl(previewEl, result.preview);
  }
  document.getElementById('compareBtn').disabled = !(parsedA && parsedB);
}
function reEncodeFile(drive) {
  const enc  = document.getElementById('enc'+drive).value;
  const name = window['_rawName_'+drive] || 'file';
  decodeAndParse(drive, enc, name);
}
function isPreviewClean(rows) {
  if (!rows || !rows.length) return true;
  const sample = rows.slice(0,3).flat().join(' ');
  if (!sample.trim()) return true;
  const junk = (sample.match(/[^\x20-\x7E\t]/g)||[]).length;
  return (junk / sample.length) < 0.08;
}
function showPreviewEl(el, rows) {
  if (!rows || !rows.length) { el.style.display='none'; return; }
  const sample = rows.slice(0,3).map(r =>
    r.slice(0,6).map(c => '<span style="border-right:1px solid var(--border);padding:0 5px">' + escHtml(String(c).slice(0,28)) + '</span>').join('')
  ).join('<br>');
  el.innerHTML = '<div style="font-size:10px;color:var(--muted);margin-bottom:3px">First 3 data rows:</div>'
    + '<div style="font-family:Consolas,monospace;font-size:11px;overflow:hidden;white-space:nowrap;color:var(--text)">' + sample + '</div>';
  el.style.display='block';
}
function showEncodingPicker(drive) { const el = document.getElementById('encRow'+drive); if (el) el.style.display='flex'; }
function hideEncodingPicker(drive) { const el = document.getElementById('encRow'+drive); if (el) el.style.display='none'; }
function parseTextParams(text) {
  const lines = text.split(/\r?\n/).filter(l => l.trim().length > 0);
  if (!lines.length) return { error: 'File is empty' };
  const sample5 = lines.slice(0,Math.min(5,lines.length)).join('\n');
  const tabs = (sample5.match(/\t/g)||[]).length;
  const commas = (sample5.match(/,/g)||[]).length;
  const delim = tabs >= commas ? '\t' : ',';
  const sanitise = s => {
    s = s.replace(/[\uFFFD\uFFFE\uFFFF\uD800-\uDFFF]/g, '');
    s = s.replace(/[\x00-\x08\x0B\x0C\x0E-\x1F\x7F]/g, '');
    return s.replace(/^"|"$/g,'').trim();
  };
  const rows = lines.map(l => l.split(delim).map(sanitise));
  let colNum=-1, colName=-1, colVal=-1, colDflt=-1, colMin=-1, colMax=-1, colUnit=-1, dataStart=0;
  for (let i=0; i<Math.min(6,rows.length); i++) {
    const r = rows[i].map(c => c.toLowerCase().trim());
    const nameIdx = r.findIndex(c => c==='name' || c==='param name');
    const numIdx  = r.findIndex(c => c==='#' || c==='param #' || c==='param#' || c==='number');
    const valIdx  = r.findIndex(c => c==='value' || c==='val');
    if (nameIdx >= 0) {
      colName = nameIdx; colNum = numIdx>=0 ? numIdx : Math.max(0,nameIdx-1);
      colVal  = valIdx>=0 ? valIdx : nameIdx+1;
      colUnit = r.findIndex(c => c==='units' || c==='unit');
      colDflt = r.findIndex(c => c==='default' || c==='factory default' || c==='default value' || c==='dflt');
      colMin  = r.findIndex(c => c==='min' || c==='minimum' || c==='min value');
      colMax  = r.findIndex(c => c==='max' || c==='maximum' || c==='max value');
      dataStart = i+1; break;
    }
  }
  if (colNum<0) { colNum=1; colName=2; colVal=3; }
  const params = new Map();
  const preview = [];
  for (let i=dataStart; i<rows.length; i++) {
    const r = rows[i];
    if (r.length <= colName) continue;
    const num = parseInt(r[colNum]||'', 10);
    if (isNaN(num) || num<0 || num>99999) continue;
    const name = (r[colName]||'').trim();
    if (!name || name.length<2 || /^\d+$/.test(name)) continue;
    const val = colVal<r.length ? (r[colVal]||'').trim() : '';
    const cell = ci => (ci>=0 && ci<r.length) ? (r[ci]||'').trim() : '';
    if (!params.has(num)) {
      const entry = { num, name, value: val };
      const u = cell(colUnit), d = cell(colDflt), mn = cell(colMin), mx = cell(colMax);
      if (u)  entry.unit = u;
      if (d)  entry.dflt = d;
      if (mn) entry.min  = mn;
      if (mx) entry.max  = mx;
      params.set(num, entry);
      if (preview.length<5) preview.push(r);
    }
  }
  if (params.size === 0) return { error: 'No parameters found — check file format' };
  return { params, preview };
}
