function mapToObj(m) {
  const o = {};
  m.forEach((v, k) => { o[k] = v; });
  return o;
}

function parsedMapToArray(m) {
  if (!m) return null;
  const arr = [];
  m.forEach((p) => arr.push(p));
  return arr;
}

function arrayToParsedMap(arr) {
  if (!arr) return null;
  const m = new Map();
  arr.forEach(p => m.set(p.num, p));
  return m;
}

function buildProjectPayload() {
  if (!parsedA && !parsedB && currentRows.length === 0) return null;

  const projName = document.getElementById('projNameInput').value.trim()
    || document.getElementById('nameA').value + ' → ' + document.getElementById('nameB').value;

  const verifiedArr = [];
  _verifiedKeys.forEach(k => {
    if (k.startsWith(sessionKey + '||')) verifiedArr.push(k.slice(sessionKey.length + 2));
  });

  const reviewArr = [];
  _reviewKeys.forEach(k => {
    if (k.startsWith(sessionKey + '||')) reviewArr.push(k.slice(sessionKey.length + 2));
  });

  const project = {
    version:    PROJECT_VERSION,
    savedAt:    new Date().toISOString(),
    projName,
    nameA:      document.getElementById('nameA').value,
    nameB:      document.getElementById('nameB').value,
    parsedA:    parsedMapToArray(parsedA),
    parsedB:    parsedMapToArray(parsedB),
    userNotes:  mapToObj(userNotes),
    bvalOverrides: mapToObj(bvalOverrides),
    critOverrides: mapToObj(critOverrides),
    userRemaps: mapToObj(new Map([...userRemaps].map(([k,v]) => [k, v]))),
    learnedMaps: learnedMaps,
    verified:   verifiedArr,
    review:     reviewArr,
    sortCol,
    sortDir,
    hideSecondary,
    unverifiedOnly,
  };

  try { if (window._iuuxB64_A && window._iuuxMeta_A) project.iuuxA = { b64: window._iuuxB64_A, meta: window._iuuxMeta_A }; } catch(e){}
  try { if (window._iuuxB64_B && window._iuuxMeta_B) project.iuuxB = { b64: window._iuuxB64_B, meta: window._iuuxMeta_B }; } catch(e){}

  const json = JSON.stringify(project, null, 2);
  const safeName = projName.replace(/[^a-zA-Z0-9_\- ]/g, '_').trim().replace(/\s+/g, '_') || 'VFD_Project';
  return { json, safeName };
}

let projectFileHandle = null;
const fsaSupported = () => (typeof window !== 'undefined' && 'showSaveFilePicker' in window);

async function saveProject() {
  const p = buildProjectPayload();
  if (!p) { setProjStatus('Nothing to save — load parameter files first', 'err'); return; }
  await persistProject(p.json, p.safeName, false);
