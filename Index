function applyLearnedMaps(){
  _learnedApplied = new Set();
  if (!learnedMaps || !Object.keys(learnedMaps).length) return;
  currentRows.forEach(row=>{
    const key = rowKey(row);
    if (userRemaps.has(key)) return;                       // respect this-session manual choices
    const learned = learnedMaps[_normName(row.pA.name)];
    if (!learned) return;
    if (learned.num === null || learned.num === undefined) {
      if (row.pB) { userRemaps.set(key, null); _learnedApplied.add(key); }
    } else {
      const target = parsedB ? (parsedB.get(learned.num) || null) : null;
      if (target && (!row.pB || row.pB.num !== learned.num)) { userRemaps.set(key, target); _learnedApplied.add(key); }
    }
  });
}
