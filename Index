  }
  return { params, driveName, modPath:modIdx[i], modInnerName: modInner?modInner.name:null, scaleByNum, enumTextToVal:textToVal };
}

async function parseIuuxFile(drive, file){
  if (typeof JSZip==='undefined'){ setStatus(drive,'✗ Zip library (JSZip) not loaded — check your internet connection','err'); return; }
  let bytes;
  try { bytes=await file.arrayBuffer(); } catch(e){ setStatus(drive,'✗ Could not read file','err'); return; }
  let info;
  try { info=await iuuxExtract(bytes); }
  catch(e){ setStatus(drive,'✗ Error parsing .iuux: '+e.message,'err'); return; }
  if (!info || info.params.size===0){
    setStatus(drive,'✗ No drive parameters found in .iuux','err');
    if (drive==='A') parsedA=null; else parsedB=null;
  } else {
    if (drive==='A') parsedA=info.params; else parsedB=info.params;
    window['_iuuxBytes_'+drive]=bytes;
    try { window['_iuuxB64_'+drive]=_ab2b64(bytes); } catch(e){ window['_iuuxB64_'+drive]=null; }
    window['_iuuxMeta_'+drive]={ modPath:info.modPath, modInnerName:info.modInnerName, scaleByNum:info.scaleByNum, enumTextToVal:info.enumTextToVal };
    hideEncodingPicker(drive);
    setStatus(drive,'✓ Loaded '+info.params.size+' parameters from .iuux'+(info.driveName?' ('+info.driveName+')':''),'ok');
    const nameEl=document.getElementById('name'+drive);
    if (nameEl && (nameEl.value==='Drive '+drive || nameEl.value==='')) nameEl.value=info.driveName||file.name.replace(/\.iuux$/i,'');
    if (drive==='A') helpFamA=detectHelpFamily(info.driveName)||helpFamA; else helpFamB=detectHelpFamily(info.driveName)||helpFamB;
    updateIuuxExportBtn();
  }
  document.getElementById('compareBtn').disabled = !(parsedA && parsedB);
}

async function exportIuux(drive){
  const b64s  = window['_iuuxB64_'+drive];
  const bytes = b64s ? _b642ab(b64s) : window['_iuuxBytes_'+drive];
  const meta  = window['_iuuxMeta_'+drive];
  if (!bytes || !meta){ setProjStatus('Load a .iuux for Drive '+drive+' first','err'); return; }
  const edits = new Map();
  currentRows.forEach(row=>{
    const p = drive==='A' ? row.pA : row.pB;
    if (!p) return;
    const ov = bvalOverrides.get(rowKey(row));
    if (ov!==undefined) edits.set(p.num, ov);
  });
  try {
    const outer = await JSZip.loadAsync(bytes);
    const modZip = await JSZip.loadAsync(await outer.file(meta.modPath).async('uint8array'));
    let xml = (await modZip.file(meta.modInnerName).async('string')).replace(/\u0000/g,'');
    let applied=0;
    edits.forEach((disp, num)=>{
      const div = meta.scaleByNum[num] || 1;
      const ttv = meta.enumTextToVal[num];
      let raw = _iuuxDisplayToRaw(disp, div, ttv);
      if (raw===null || isNaN(raw)) return;
      if (raw<0) raw = raw >>> 0;
      const hexnum = num.toString(16).toUpperCase();
      const hexval = raw.toString(16).toUpperCase();
      const re = new RegExp('(<ParamX Num="'+hexnum+'" Value=")[0-9A-Fa-f]+("\\s*/>)');
      if (re.test(xml)) xml = xml.replace(re, '$1'+hexval+'$2');
      else xml = xml.replace('</Parameters>', '<ParamX Num="'+hexnum+'" Value="'+hexval+'" /></Parameters>');
      applied++;
    });
    modZip.file(meta.modInnerName, xml);
    const newMod = await modZip.generateAsync({type:'uint8array', compression:'DEFLATE'});
    outer.file(meta.modPath, newMod);
    const blob = await outer.generateAsync({type:'blob', compression:'DEFLATE'});
    const nm = (document.getElementById('name'+drive).value || ('Drive_'+drive)).replace(/[^a-zA-Z0-9_\- ]/g,'_').trim().replace(/\s+/g,'_') || 'Drive';
    const fname = nm + '_updated.iuux';
    if (fsaSupported()){
      try {
        const h = await window.showSaveFilePicker({ suggestedName:fname, types:[{description:'CCW Project', accept:{'application/octet-stream':['.iuux']}}] });
        const w = await h.createWritable(); await w.write(blob); await w.close();
        setProjStatus('✓ Exported '+applied+' edited value(s) to '+(h.name||fname), 'ok'); return;
      } catch(e){ if(e&&e.name==='AbortError'){ setProjStatus('Export cancelled',''); return; } }
    }
    const url=URL.createObjectURL(blob); const a=document.createElement('a'); a.href=url; a.download=fname;
    document.body.appendChild(a); a.click(); document.body.removeChild(a); URL.revokeObjectURL(url);
    setProjStatus('✓ Exported '+applied+' edited value(s): '+fname, 'ok');
  } catch(e){
    setProjStatus('✗ Export failed: '+e.message, 'err');
  }
}

function updateIuuxExportBtn(){
