    if (pA.dflt !== undefined && pA.dflt !== '') aDmmHtml += `<span class="dmm-dflt">${escHtml(String(pA.dflt))}</span>`;
    if (pA.min !== undefined && pA.min !== '' && pA.max !== undefined && pA.max !== '') {
