function escHtml(s) {
  if (s == null) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

let activeNoteIdx = null;

function openNoteEditor(idx, displayEl) {
  if (activeNoteIdx !== null && activeNoteIdx !== idx) closeNoteEditor(activeNoteIdx);
  activeNoteIdx = idx;
  const editor = document.getElementById('noteEditor_' + idx);
  if (!editor) return;
  editor.classList.add('active');
  const ta = document.getElementById('noteTa_' + idx);
  if (ta) {
    ta.focus();
    ta.setSelectionRange(ta.value.length, ta.value.length);
    ta.addEventListener('keydown', noteKeyHandler);
  }
}

function noteKeyHandler(e) {
  if (e.key === 'Enter' && e.shiftKey) {
    e.preventDefault();
    const editorEl = e.target.closest('.note-editor');
    if (!editorEl) return;
    const idStr = editorEl.id.replace('noteEditor_', '');
    saveNote(parseInt(idStr));
  } else if (e.key === 'Escape') {
    const editorEl = e.target.closest('.note-editor');
    if (!editorEl) return;
    const idStr = editorEl.id.replace('noteEditor_', '');
    closeNoteEditor(parseInt(idStr));
  }
}

function closeNoteEditor(idx) {
  const editor = document.getElementById('noteEditor_' + idx);
  if (editor) editor.classList.remove('active');
  const ta = document.getElementById('noteTa_' + idx);
  if (ta) ta.removeEventListener('keydown', noteKeyHandler);
  if (activeNoteIdx === idx) activeNoteIdx = null;
}

function closeAllNoteEditors() {
  document.querySelectorAll('.note-editor.active').forEach(ed => ed.classList.remove('active'));
  activeNoteIdx = null;
}

function saveNote(idx) {
  const row = currentRows[idx];
  if (!row) return;
  const ta = document.getElementById('noteTa_' + idx);
  if (!ta) return;
  const val = ta.value.trim();
  const key = rowKey(row);
  if (val) {
    userNotes.set(key, val);
  } else {
    userNotes.delete(key);
  }
  closeNoteEditor(idx);
  const tr = document.querySelector(`tr[data-idx="${idx}"]`);
  if (tr) {
    const manualNote = row.manualNote || '';
    const displayNote = val || manualNote;
    const noteClass = val ? 'has-user' : (manualNote ? 'has-manual' : '');
    const displayEl = tr.querySelector('.note-display');
    if (displayEl) {
      displayEl.textContent = displayNote;
      displayEl.className = 'note-display ' + noteClass;
    }
    tr.dataset.noted = (val || manualNote) ? '1' : '0';
