async function _iuuxReadInner(zipBytes, pred){
  const z = await JSZip.loadAsync(zipBytes);
  for (const name of Object.keys(z.files)){
    if (!name.endsWith('.xml')) continue;
    const t = (await z.file(name).async('string')).replace(/\u0000/g,'');
    if (pred(t)) return { name, text:t };
  }
