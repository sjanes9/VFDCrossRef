function applyLoadedProject(rawText, fileName) {
    let project;
    try {
      project = JSON.parse(rawText);
    } catch(err) {
      setProjStatus('✗ Could not read project file — invalid JSON', 'err');
      return;
    }

    if (!project.version || !project.parsedA || !project.parsedB) {
      setProjStatus('✗ File does not appear to be a valid .vfdproj file', 'err');
      return;
    }

    parsedA = arrayToParsedMap(project.parsedA);
    parsedB = arrayToParsedMap(project.parsedB);

    // restore embedded .iuux data so the Export (.iuux) button works after a project load
    window._iuuxBytes_A = undefined; window._iuuxMeta_A = undefined; window._iuuxB64_A = undefined;
    window._iuuxBytes_B = undefined; window._iuuxMeta_B = undefined; window._iuuxB64_B = undefined;
    try { if (project.iuuxA && project.iuuxA.b64){ window._iuuxB64_A=project.iuuxA.b64; window._iuuxMeta_A=project.iuuxA.meta; } } catch(e){}
    try { if (project.iuuxB && project.iuuxB.b64){ window._iuuxB64_B=project.iuuxB.b64; window._iuuxMeta_B=project.iuuxB.meta; } } catch(e){}

    document.getElementById('nameA').value = project.nameA || 'Drive A';
    document.getElementById('nameB').value = project.nameB || 'Drive B';

    document.getElementById('projNameInput').value = project.projName || '';

    setStatus('A', `✓ Loaded ${parsedA.size} parameters (from project file)`, 'ok');
    setStatus('B', `✓ Loaded ${parsedB.size} parameters (from project file)`, 'ok');
    document.getElementById('compareBtn').disabled = false;

    runCompare();
    updateIuuxExportBtn();

    userNotes = new Map();
    if (project.userNotes) {
      Object.entries(project.userNotes).forEach(([k, v]) => userNotes.set(k, v));
    }

    bvalOverrides = new Map();
    if (project.bvalOverrides) {
      Object.entries(project.bvalOverrides).forEach(([k, v]) => bvalOverrides.set(k, v));
    }
    critOverrides = new Map();
    if (project.critOverrides) {
      Object.entries(project.critOverrides).forEach(([k, v]) => critOverrides.set(k, v));
    }

    userRemaps = new Map();
    if (project.userRemaps) {
      Object.entries(project.userRemaps).forEach(([k, v]) => userRemaps.set(k, v));
    }
    if (project.learnedMaps && typeof project.learnedMaps === 'object') {
      Object.assign(learnedMaps, project.learnedMaps);
      saveLearnedMaps();
    }

    _verifiedKeys = new Set();
    if (project.verified && Array.isArray(project.verified)) {
      project.verified.forEach(k => _verifiedKeys.add(sessionKey + '||' + k));
    }

    _reviewKeys = new Set();
    if (project.review && Array.isArray(project.review)) {
      project.review.forEach(k => _reviewKeys.add(sessionKey + '||' + k));
    }

    if (project.sortCol) { sortCol = project.sortCol; sortDir = project.sortDir || 'asc'; }
    hideSecondary = !!project.hideSecondary;
    unverifiedOnly = !!project.unverifiedOnly;
    document.getElementById('btnHideSecondary').classList.toggle('active', hideSecondary);
    document.getElementById('btnUnverified').classList.toggle('active', unverifiedOnly);

    sortRows();
    renderTable();
    updateProgress();

    const savedAt = project.savedAt ? ' (saved ' + new Date(project.savedAt).toLocaleDateString() + ')' : '';
    setProjStatus('✓ Project loaded: ' + (project.projName || fileName) + savedAt, 'ok');
}

