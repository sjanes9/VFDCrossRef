function handleFile(drive, input) {
  const file = input.files[0];
  if (!file) return;
  setStatus(drive, 'Reading…', '');
  const lower = file.name.toLowerCase();
  const isPDF  = lower.endsWith('.pdf') || file.type === 'application/pdf';
  const isIuux = lower.endsWith('.iuux');
  if (isIuux) {
    parseIuuxFile(drive, file);
  } else if (isPDF) {
    parsePDFFile(drive, file);
  } else {
    const reader = new FileReader();
    reader.onload = e => {
      const buf = e.target.result;
      const enc = detectEncoding(buf);
      const encSel = document.getElementById('enc'+drive);
      if (encSel) encSel.value = enc;
      window['_rawBuf_'+drive] = buf;
      window['_rawName_'+drive] = file.name;
      decodeAndParse(drive, enc, file.name);
    };
    reader.readAsArrayBuffer(file);
  }
}

