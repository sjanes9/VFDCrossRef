function runCompare() {
  if (!parsedA || !parsedB) return;

  const nameA = document.getElementById('nameA').value || 'Drive A';
  const nameB = document.getElementById('nameB').value || 'Drive B';
  document.getElementById('driveALabel').textContent = nameA;
  document.getElementById('driveBLabel').textContent = nameB;
  document.getElementById('badgeA').textContent = nameA;
  document.getElementById('badgeB').textContent = nameB;
  document.getElementById('headNameAText').textContent = nameA + ' Parameter';
  document.getElementById('headNameBText').textContent = nameB + ' Parameter';
  document.getElementById('driveBadges').style.display = 'flex';

  sessionKey = 'vfd_v8_' + nameA.replace(/\s+/g,'_') + '_to_' + nameB.replace(/\s+/g,'_');

  const normalise = s => s.toLowerCase().replace(/\s+/g,'').replace(/[^a-z0-9]/g,'');

  const nameMapB = new Map();
  parsedB.forEach((p, num) => { nameMapB.set(normalise(p.name), p); });
  const numMapB = new Map();
  parsedB.forEach((p, num) => { numMapB.set(num, p); });

  currentRows = [];
  let xrefHits = 0, nameHits = 0, nomaps = 0;

  parsedA.forEach((pA, numA) => {
    const isRO = readOnlyNums.has(numA);
    const xrefEntry = xrefByPF70Num.get(numA);

    let pB = null;
    let matchSource = 'none';
    let manualNote = '';

    if (xrefEntry) {
      manualNote = xrefEntry.note || '';
      if (xrefEntry.pf525_num !== null) {
        pB = numMapB.get(xrefEntry.pf525_num);
        if (!pB) {
          pB = nameMapB.get(normalise(xrefEntry.pf525_name || '')) || null;
        }
        if (pB) { matchSource = 'xref'; xrefHits++; }
      }
    }

    if (!pB && !xrefEntry) {
      pB = nameMapB.get(normalise(pA.name)) || null;
      if (pB) { matchSource = 'name'; nameHits++; }
    }

    if (!pB && !xrefEntry) nomaps++;
    else if (!pB && xrefEntry && xrefEntry.pf525_num === null) nomaps++;

    let status;
    if (isRO) {
      status = 'ro';
    } else if (!pB) {
      status = 'nomap';
    } else {
      const vA = normaliseVal(pA.value);
      const vB = normaliseVal(pB.value);
      status = (vA === vB) ? 'same' : 'diff';
    }

    let isPrimary = true;
    let manyToOneNote = '';
    if (pB) {
      const m2o = MANY_TO_ONE.get(pB.num);
      if (m2o) {
        if (m2o.primary === pA.num) {
          isPrimary = true;
        } else {
          isPrimary = false;
          manyToOneNote = m2o.secondaryNote;
        }
      }
    }
    if (!pB) isPrimary = true;

    currentRows.push({ pA, pB, status, matchSource, manualNote, isPrimary, manyToOneNote });
  });

  applyLearnedMaps();

  sortCol = 'status';
  sortDir = 'asc';
  sortRows();

  document.getElementById('xrefPanel').classList.add('visible');
  document.getElementById('xrefInfo').textContent =
    `${xrefHits} params mapped via manual cross-reference · ${nameHits} matched by name · ${nomaps} unmapped`;

  renderTable();
  document.getElementById('emptyState').style.display = 'none';
  document.getElementById('tableWrap').style.display = 'block';
  document.getElementById('controls').style.display = 'flex';
  document.getElementById('countBar').style.display = 'block';
  document.getElementById('progressBar').classList.add('visible');
  updateProgress();
}

const STATUS_ORDER = { diff:0, same:1, nomap:2, ro:3 };

function sortRows() {
  const dir = sortDir === 'asc' ? 1 : -1;

  currentRows.sort((a, b) => {
    let av, bv;
    switch (sortCol) {
      case 'priority': {
        const po = CRIT_ORDER[effectiveCrit(a)] - CRIT_ORDER[effectiveCrit(b)];
        if (po !== 0) return dir * po;
        return a.pA.num - b.pA.num;
      }
      case 'anum':
        return dir * (a.pA.num - b.pA.num);
      case 'aname':
        return dir * a.pA.name.localeCompare(b.pA.name);
      case 'aval':
        av = a.pA.value || ''; bv = b.pA.value || '';
        return dir * (parseFloat(av) - parseFloat(bv) || av.localeCompare(bv));
      case 'bnum':
        av = a.pB ? a.pB.num : Infinity; bv = b.pB ? b.pB.num : Infinity;
        return dir * (av - bv);
      case 'bname':
        av = a.pB ? a.pB.name : ''; bv = b.pB ? b.pB.name : '';
        return dir * av.localeCompare(bv);
      case 'bval':
        av = a.pB ? (a.pB.value || '') : ''; bv = b.pB ? (b.pB.value || '') : '';
        return dir * (parseFloat(av) - parseFloat(bv) || av.localeCompare(bv));
      case 'status':
      default: {
        const so = STATUS_ORDER[a.status] - STATUS_ORDER[b.status];
        if (so !== 0) return dir * so;
        return a.pA.num - b.pA.num;
      }
    }
  });
}

function sortBy(col) {
  if (sortCol === col) {
    sortDir = sortDir === 'asc' ? 'desc' : 'asc';
  } else {
    sortCol = col;
    sortDir = 'asc';
  }
  sortRows();

  const colMap = {
    anum:'thA0', aname:'headNameA', aval:'thA2',
    bnum:'thB0', bname:'headNameB', bval:'thB2', status:'thStatus'
  };
  document.querySelectorAll('thead th').forEach(th => {
    th.classList.remove('sorted-asc','sorted-desc');
    const arrow = th.querySelector('.sort-arrow');
    if (arrow) arrow.textContent = '⇅';
  });
  const activeTh = document.getElementById(colMap[col]);
  if (activeTh) {
    activeTh.classList.add(sortDir === 'asc' ? 'sorted-asc' : 'sorted-desc');
    const arrow = activeTh.querySelector('.sort-arrow');
    if (arrow) arrow.textContent = sortDir === 'asc' ? '▲' : '▼';
  }

  renderTable();
}

function normaliseVal(v) {
  if (v === null || v === undefined || v === '') return '';
  let s = v.toString()
    .replace(/\s*(Hz|VAC|VDC|kHz|kW|RPM|Amps?|Secs?|Sec|Hrs?|Hr|%|kbps|R\/s|V|A|C|mH|Ohm|mSec|PPR|x10h|kWh|MWh|kg|deg)\s*$/i, '')
    .replace(/\s+/g, ' ').trim();
  const n = parseFloat(s);
  if (!isNaN(n) && String(n) !== 'NaN' && s.match(/^-?\d+\.?\d*$/)) return String(n);
  return s.toLowerCase();
}

function rowKey(row) { return `${row.pA.num}_${row.pA.name}`; }

