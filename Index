<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VFD Parameter Cross-Reference — PF70 / PF525</title>
<style>
  :root {
    --bg: #0f1117;
    --surface: #1a1d27;
    --surface2: #22263a;
    --border: #2e3350;
    --accent: #4f8ef7;
    --accent2: #f7a14f;
    --green: #4fca7a;
    --yellow: #f7d44f;
    --red: #f74f4f;
    --text: #e2e6f0;
    --muted: #7a83a6;
    --header-bg: #131621;
    --verified-bg: rgba(79,202,122,0.06);
    --note-edit-bg: rgba(79,142,247,0.07);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'Segoe UI', system-ui, sans-serif; font-size: 13px; min-height: 100vh; }

  
  header {
    background: var(--header-bg);
    border-bottom: 2px solid var(--accent);
    padding: 16px 24px 12px;
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
  }
  header h1 { font-size: 17px; font-weight: 700; letter-spacing: 0.03em; }
  header h1 span.a { color: var(--accent); }
  header h1 span.b { color: var(--accent2); }
  .drive-labels { display: flex; gap: 10px; margin-left: auto; }
  .drive-badge {
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 4px; padding: 3px 10px; font-size: 11px;
    color: var(--muted); letter-spacing: 0.05em; white-space: nowrap;
  }
  .drive-badge.a { border-color: var(--accent); color: var(--accent); }
  .drive-badge.b { border-color: var(--accent2); color: var(--accent2); }
  .manual-badge {
    background: rgba(79,202,122,0.08); border: 1px solid rgba(79,202,122,0.3);
    border-radius: 4px; padding: 3px 10px; font-size: 10px;
    color: var(--green); letter-spacing: 0.05em; white-space: nowrap;
  }

  
  #uploadPanel {
    background: var(--surface); border-bottom: 1px solid var(--border);
    padding: 14px 24px; display: flex; gap: 20px; flex-wrap: wrap; align-items: flex-start;
  }
  .upload-slot { flex: 1; min-width: 260px; max-width: 480px; }
  .upload-slot label { display: block; font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
  .upload-slot label span { font-size: 10px; }
  .drop-zone {
    border: 1px dashed var(--border); border-radius: 8px;
    background: var(--bg); padding: 12px 16px;
    display: flex; align-items: center; gap: 12px;
    cursor: pointer; transition: border-color 0.15s;
    position: relative;
  }
  .drop-zone:hover, .drop-zone.drag-over { border-color: var(--accent); }
  .drop-zone input[type=file] { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
  .drop-icon { font-size: 22px; color: var(--muted); flex-shrink: 0; }
  .drop-text { font-size: 12px; color: var(--muted); line-height: 1.5; }
  .drop-text strong { color: var(--text); display: block; font-size: 13px; }
  .drop-text small { font-size: 10px; }
  .upload-status { margin-top: 6px; font-size: 11px; color: var(--muted); min-height: 16px; }
  .upload-status.ok { color: var(--green); }
  .upload-status.err { color: var(--red); }
  .compare-btn {
    align-self: flex-end; padding: 9px 22px; border-radius: 6px;
    background: var(--accent); color: #fff; border: none; font-size: 13px;
    font-weight: 600; cursor: pointer; transition: opacity 0.15s; white-space: nowrap;
  }
  .compare-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .compare-btn:not(:disabled):hover { opacity: 0.85; }
  .format-hint {
    flex-basis: 100%; font-size: 11px; color: var(--muted); padding: 4px 0 0;
    border-top: 1px solid var(--border); margin-top: 4px;
  }
  .format-hint code { background: var(--surface2); border-radius: 3px; padding: 1px 5px; font-family: Consolas, monospace; font-size: 10px; color: var(--text); }

  
  #progressBar {
    background: var(--surface); border-bottom: 1px solid var(--border);
    padding: 8px 24px; display: none; align-items: center; gap: 16px;
  }
  #progressBar.visible { display: flex; }
  .prog-track { flex: 1; background: var(--bg); border-radius: 4px; height: 6px; overflow: hidden; border: 1px solid var(--border); }
  .prog-fill { height: 100%; background: var(--green); border-radius: 4px; transition: width 0.3s; width: 0%; }
  .prog-label { font-size: 11px; color: var(--muted); white-space: nowrap; }
  .prog-label span { color: var(--green); font-weight: 600; }
  .prog-reset { font-size: 11px; color: var(--muted); cursor: pointer; text-decoration: underline; }
  .prog-reset:hover { color: var(--red); }
  .export-btn {
    font-size: 11px; color: var(--accent); cursor: pointer; text-decoration: underline;
    background: none; border: none; padding: 0;
  }
  .export-btn:hover { color: var(--text); }

  
  .controls {
    background: var(--surface); border-bottom: 1px solid var(--border);
    padding: 10px 24px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }
  .search-wrap { position: relative; flex: 1; min-width: 200px; max-width: 340px; }
  .search-wrap input {
    width: 100%; background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); padding: 7px 12px 7px 32px; font-size: 13px; outline: none;
  }
  .search-wrap input:focus { border-color: var(--accent); }
  .search-wrap::before { content: '⌕'; position: absolute; left: 9px; top: 50%; transform: translateY(-50%); color: var(--muted); font-size: 15px; pointer-events: none; }
  select {
    background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); padding: 7px 10px; font-size: 12px; cursor: pointer; outline: none;
  }
  select:focus { border-color: var(--accent); }
  .filter-btn {
    background: var(--bg); border: 1px solid var(--border); border-radius: 6px;
    color: var(--muted); padding: 6px 12px; font-size: 11px; cursor: pointer;
  }
  .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
  .legend { display: flex; gap: 14px; align-items: center; margin-left: auto; flex-wrap: wrap; }
  .legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--muted); }
  .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .dot-diff   { background: var(--yellow); }
  .dot-same   { background: var(--green); }
  .dot-nomap  { background: var(--red); }
  .dot-ro     { background: var(--muted); }

  
  .count-bar { font-size: 12px; color: var(--muted); padding: 8px 24px 0; }
  .count-bar span { color: var(--text); font-weight: 600; }

  
  .table-wrap { padding: 0 24px 32px; overflow-x: auto; }
  table { width: 100%; border-collapse: collapse; margin-top: 14px; min-width: 1000px; }
  thead th {
    background: var(--surface2); color: var(--muted); text-transform: uppercase;
    font-size: 10px; letter-spacing: 0.07em; padding: 9px 10px;
    text-align: left; border-bottom: 1px solid var(--border); white-space: nowrap;
  }
  thead th.col-a { border-top: 2px solid var(--accent); }
  thead th.col-b { border-top: 2px solid var(--accent2); }
  thead th.col-v { border-top: 2px solid var(--green); text-align: center; }
  thead th.col-xref { border-top: 2px solid var(--green); }

  
  .sort-btn {
    display: inline-flex; align-items: center; gap: 3px;
    cursor: pointer; background: none; border: none; padding: 0;
    color: inherit; font: inherit; font-size: inherit; letter-spacing: inherit;
    text-transform: inherit; white-space: nowrap;
  }
  .sort-btn:hover { color: var(--text); }
  .sort-arrow {
    font-size: 9px; color: var(--muted); line-height: 1; flex-shrink: 0;
    display: inline-block; width: 10px; text-align: center;
  }
  thead th.sorted-asc  .sort-arrow,
  thead th.sorted-desc .sort-arrow { color: var(--accent); }

  
  thead th { position: relative; user-select: none; }
  .col-resize-handle {
    position: absolute; right: 0; top: 0; bottom: 0; width: 6px;
    cursor: col-resize; z-index: 1;
  }
  .col-resize-handle:hover, .col-resize-handle.dragging {
    background: var(--accent); opacity: 0.5;
  }
  table { table-layout: fixed; }
  thead th, tbody td { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  tbody tr { border-bottom: 1px solid var(--border); transition: background 0.1s; }
  tbody tr:hover { background: var(--surface2); }
  tbody tr.hidden { display: none; }
  tbody tr.verified-row { background: var(--verified-bg); }
  tbody tr.verified-row:hover { background: rgba(79,202,122,0.1); }
  td { padding: 7px 10px; vertical-align: middle; line-height: 1.4; }
  .pnum { font-variant-numeric: tabular-nums; font-weight: 600; font-size: 12px; white-space: nowrap; color: var(--accent); }
  .pnum.b { color: var(--accent2); }
  .pname { font-weight: 500; }
  .pval { font-variant-numeric: tabular-nums; font-size: 12px; font-family: Consolas, monospace; color: var(--muted); }
  .pval.diff { color: var(--yellow); font-weight: 600; }
  .pval-unit { font-size: 9px; color: var(--muted); font-family: 'Segoe UI', system-ui, sans-serif; margin-left: 3px; opacity: 0.7; }
  .pill {
    display: inline-block; border-radius: 3px; padding: 2px 7px;
    font-size: 10px; font-weight: 700; letter-spacing: 0.03em; white-space: nowrap;
  }
  .pill-same   { background: rgba(79,202,122,0.13); color: var(--green); }
  .pill-diff   { background: rgba(247,212,79,0.13); color: var(--yellow); }
  .pill-nomap  { background: rgba(247,79,79,0.10); color: var(--red); }
  .pill-ro     { background: rgba(122,131,166,0.10); color: var(--muted); }
  .section-header td {
    background: var(--surface2); color: var(--accent); font-size: 10px;
    font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 5px 10px; border-top: 1px solid var(--border);
  }

  
  .verify-cell { text-align: center; }
  .verify-btn {
    width: 26px; height: 26px; border-radius: 5px;
    border: 1.5px solid var(--border); background: var(--bg);
    cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
    font-size: 14px; transition: all 0.15s; color: transparent;
  }
  .verify-btn:hover { border-color: var(--green); background: rgba(79,202,122,0.08); color: var(--green); }
  .verify-btn.checked { background: rgba(79,202,122,0.15); border-color: var(--green); color: var(--green); }

  /* --- "At factory default" flag on the OLD (Drive A) value --- */
  .def-badge {
    display: inline-block; margin-left: 6px; padding: 1px 5px;
    border-radius: 3px; font-size: 9px; font-weight: 700; letter-spacing: 0.03em;
    background: rgba(122,131,166,0.16); color: var(--muted);
    border: 1px solid rgba(122,131,166,0.32); vertical-align: middle; cursor: help;
  }

  /* --- "Flag for review" button + row highlight --- */
  thead th.col-rv { border-top: 2px solid var(--accent2); text-align: center; }
  .review-cell { text-align: center; }
  .review-btn {
    width: 26px; height: 26px; border-radius: 5px;
    border: 1.5px solid var(--border); background: var(--bg);
    cursor: pointer; display: inline-flex; align-items: center; justify-content: center;
    font-size: 14px; transition: all 0.15s; color: var(--muted); line-height: 1;
  }
  .review-btn:hover { border-color: var(--accent2); background: rgba(247,161,79,0.08); color: var(--accent2); }
  .review-btn.flagged { background: rgba(247,161,79,0.15); border-color: var(--accent2); color: var(--accent2); }
  tbody tr.review-row { box-shadow: inset 3px 0 0 var(--accent2); }
  tbody tr.review-row.verified-row { background: var(--verified-bg); }

  /* --- Migration priority pill --- */
  .pri-cell { text-align: center; }
  .pri-pill {
    display: inline-block; min-width: 34px; padding: 2px 6px; border-radius: 4px;
    font-size: 9px; font-weight: 700; letter-spacing: 0.04em; line-height: 1.2;
    border: 1px solid transparent; cursor: pointer; transition: filter 0.12s;
  }
  .pri-pill:hover { filter: brightness(1.12); }
  .pri-critical  { background: rgba(224,90,90,0.16);  color: var(--red);     border-color: rgba(224,90,90,0.42); }
  .pri-important { background: rgba(247,161,79,0.15);  color: var(--accent2); border-color: rgba(247,161,79,0.42); }
  .pri-standard  { background: rgba(122,131,166,0.12); color: var(--muted);   border-color: rgba(122,131,166,0.30); }
  .pri-pill.pri-ovr { box-shadow: inset 0 0 0 1.5px var(--accent); }
  thead th.col-pri { text-align: center; }
  .pri-pill.pri-legend { min-width: 0; padding: 1px 4px; cursor: default; margin-right: 2px; }

  
  .note-cell {
    position: relative; overflow: visible !important;
  }
  .note-display {
    font-size: 11px; color: var(--muted); cursor: text;
    min-height: 18px; padding: 1px 2px; border-radius: 3px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    transition: background 0.1s;
  }
  .note-display:hover { background: var(--note-edit-bg); color: var(--text); }
  .note-display.has-user { color: var(--accent2); }
  .note-display.has-manual { color: var(--green); font-size: 10px; }
  .note-editor {
    position: absolute; z-index: 100; top: 0; left: 0;
    width: max(380px, 100%);
    background: var(--surface2); border: 1px solid var(--accent);
    border-radius: 5px; padding: 6px 8px;
    display: none; flex-direction: column; gap: 4px;
    box-shadow: 0 6px 24px rgba(0,0,0,0.5);
  }
  .note-editor.active { display: flex; }
  .note-editor textarea {
    background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
    color: var(--text); font-size: 12px; font-family: 'Segoe UI', system-ui, sans-serif;
    padding: 5px 7px; resize: vertical; min-height: 56px; outline: none; width: 100%;
  }
  .note-editor textarea:focus { border-color: var(--accent); }
  .note-editor-footer {
    display: flex; gap: 6px; align-items: center; font-size: 10px; color: var(--muted);
  }
  .note-save-btn {
    background: var(--accent); color: #fff; border: none; border-radius: 4px;
    padding: 3px 10px; font-size: 11px; cursor: pointer; font-weight: 600;
  }
  .note-cancel-btn {
    background: var(--surface); color: var(--muted); border: 1px solid var(--border);
    border-radius: 4px; padding: 3px 8px; font-size: 11px; cursor: pointer;
  }
  .note-manual-ref {
    font-size: 10px; color: var(--green); margin-top: 2px; font-style: italic;
    display: none; white-space: normal; word-wrap: break-word;
    line-height: 1.5; padding: 3px 2px;
  }
  .note-manual-ref.visible { display: block; }

  
  #detailOverlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.65); backdrop-filter: blur(2px);
    align-items: flex-start; justify-content: center; padding-top: 60px;
  }
  #detailOverlay.open { display: flex; }
  #detailPanel {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 10px; width: min(680px, 96vw); max-height: 82vh;
    display: flex; flex-direction: column; overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.6);
  }
  .dp-header {
    display: flex; align-items: flex-start; gap: 12px;
    padding: 16px 20px 12px; border-bottom: 1px solid var(--border);
    flex-shrink: 0;
  }
  .dp-num {
    font-size: 11px; font-weight: 700; color: var(--accent2);
    background: rgba(247,161,79,0.1); border: 1px solid rgba(247,161,79,0.25);
    border-radius: 4px; padding: 3px 8px; white-space: nowrap; margin-top: 2px;
  }
  .dp-title { flex: 1; min-width: 0; }
  .dp-name { font-size: 15px; font-weight: 700; color: var(--text); }
  .dp-group { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .dp-source { font-size: 10px; color: var(--green); margin-top: 3px; font-style: italic; }
  .dp-close {
    background: none; border: 1px solid var(--border); color: var(--muted);
    border-radius: 5px; width: 28px; height: 28px; cursor: pointer; font-size: 14px;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .dp-close:hover { background: var(--surface2); color: var(--text); }
  .dp-body { padding: 18px 20px; overflow-y: auto; flex: 1; }
  .dp-section-title {
    font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 8px; margin-top: 16px;
  }
  .dp-section-title:first-child { margin-top: 0; }
  .dp-desc {
    font-size: 13px; color: var(--text); line-height: 1.65; background: var(--surface2);
    border-radius: 6px; padding: 10px 14px;
  }
  .dp-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 0;
  }
  .dp-field {
    background: var(--bg); border: 1px solid var(--border); border-radius: 5px;
    padding: 8px 12px;
  }
  .dp-field-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px; }
  .dp-field-value { font-size: 12px; color: var(--text); font-family: Consolas, monospace; }
  .dp-options {
    background: var(--bg); border: 1px solid var(--border); border-radius: 5px;
  }
  .dp-option-row {
    display: flex; gap: 10px; align-items: baseline;
    padding: 6px 12px; border-bottom: 1px solid var(--border); font-size: 12px;
    flex-wrap: wrap;
  }
  .dp-option-row:last-child { border-bottom: none; }
  .dp-option-row.dp-default { background: rgba(79,202,122,0.06); }
  .dp-option-num { color: var(--muted); font-family: Consolas, monospace; min-width: 22px; font-size: 11px; flex-shrink: 0; }
  .dp-option-val { color: var(--accent2); font-family: Consolas, monospace; min-width: 130px; flex-shrink: 0; }
  .dp-option-desc { color: var(--muted); font-size: 11px; flex: 1; min-width: 140px; line-height: 1.45; white-space: normal; }
  .dp-option-apply {
    background: var(--accent); color: #fff; border: none; border-radius: 3px;
    padding: 2px 8px; font-size: 10px; font-weight: 600; cursor: pointer; flex-shrink: 0;
    margin-left: auto;
  }
  .dp-option-apply:hover { opacity: 0.82; }
  .dp-default-tag { font-size: 9px; color: var(--green); font-weight: 700; background: rgba(79,202,122,0.12); border-radius: 3px; padding: 1px 5px; margin-left: 4px; }
  .dp-suggested {
    background: rgba(79,142,247,0.07); border: 1px solid rgba(79,142,247,0.2);
    border-radius: 6px; padding: 10px 14px; font-size: 12px; color: var(--text); line-height: 1.6;
  }
  .dp-suggested::before { content: '💡 '; }
  .dp-units-chip {
    display: inline-flex; align-items: center; gap: 4px;
    background: rgba(79,142,247,0.1); border: 1px solid rgba(79,142,247,0.25);
    border-radius: 4px; padding: 2px 8px; font-size: 11px; font-weight: 700;
    color: var(--accent); font-family: Consolas, monospace; vertical-align: middle;
    margin-left: 6px;
  }
  .dp-footer {
    padding: 12px 20px; border-top: 1px solid var(--border); flex-shrink: 0;
    display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
  }
  .dp-apply-btn {
    background: var(--accent); color: #fff; border: none; border-radius: 5px;
    padding: 7px 16px; font-size: 12px; font-weight: 600; cursor: pointer;
  }
  .dp-apply-btn:hover { opacity: 0.85; }
  .dp-apply-hint { font-size: 11px; color: var(--muted); }
  .dp-no-data { font-size: 12px; color: var(--muted); font-style: italic; padding: 8px 0; }
  .dp-xref-note {
    font-size: 11px; color: var(--green); background: rgba(79,202,122,0.07);
    border: 1px solid rgba(79,202,122,0.2); border-radius: 5px;
    padding: 8px 12px; line-height: 1.55;
  }
  .dp-xref-note::before { content: '📘 '; }

  
  .bval-cell { position: relative; overflow: visible !important; }
  .bval-display {
    font-variant-numeric: tabular-nums; font-size: 12px;
    font-family: Consolas, monospace; color: var(--muted);
    cursor: pointer; padding: 1px 3px; border-radius: 3px;
    display: flex; align-items: center; gap: 4px; min-height: 18px;
  }
  .bval-display.diff { color: var(--yellow); font-weight: 600; }
  .bval-display:hover { background: rgba(247,161,79,0.07); }
  .bval-display.ro-val { cursor: default; }
  .bval-display.ro-val:hover { background: none; }
  .bval-edit-icon {
    font-size: 9px; color: var(--muted); opacity: 0; transition: opacity 0.1s;
    flex-shrink: 0;
  }
  .bval-display:not(.ro-val):hover .bval-edit-icon { opacity: 1; }
  .bval-editor {
    position: absolute; z-index: 110; top: -4px; left: -4px;
    background: var(--surface2); border: 1px solid var(--accent2);
    border-radius: 6px; padding: 6px 8px; display: none; flex-direction: column; gap: 5px;
    min-width: 200px; box-shadow: 0 6px 24px rgba(0,0,0,0.5);
  }
  .bval-editor.active { display: flex; }
  .bval-editor-label { font-size: 10px; color: var(--muted); }
  .bval-input {
    background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
    color: var(--text); font-size: 12px; font-family: Consolas, monospace;
    padding: 5px 8px; outline: none; width: 100%;
  }
  .bval-input:focus { border-color: var(--accent2); }
  .bval-select {
    background: var(--bg); border: 1px solid var(--border); border-radius: 4px;
