function openBvalEditor(idx, displayEl) {
  if (activeEditIdx !== null && activeEditIdx !== idx) closeBvalEditor(activeEditIdx);
  activeEditIdx = idx;
  const editor = document.getElementById('bvalEditor_' + idx);
  if (!editor) return;
  editor.classList.add('active');
  const inp = document.getElementById('bvalInput_' + idx);
  if (inp) {
    inp.focus();
    if (inp.tagName === 'INPUT') { inp.select(); }
    inp.addEventListener('keydown', bvalKeyHandler);
  }
}

function bvalKeyHandler(e) {
  if (e.key === 'Enter') {
    e.preventDefault();
    const editorEl = e.target.closest('.bval-editor');
    if (!editorEl) return;
    saveBval(parseInt(editorEl.id.replace('bvalEditor_', '')));
  } else if (e.key === 'Escape') {
    const editorEl = e.target.closest('.bval-editor');
    if (!editorEl) return;
    closeBvalEditor(parseInt(editorEl.id.replace('bvalEditor_', '')));
  }
}

function closeBvalEditor(idx) {
  const editor = document.getElementById('bvalEditor_' + idx);
  if (editor) editor.classList.remove('active');
  const inp = document.getElementById('bvalInput_' + idx);
  if (inp) inp.removeEventListener('keydown', bvalKeyHandler);
  if (activeEditIdx === idx) activeEditIdx = null;
}

function saveBval(idx) {
  const row = currentRows[idx];
  if (!row) return;
  const remapKey = rowKey(row);
  const userRemap = userRemaps.get(remapKey);
  const effectivePB = userRemap !== undefined ? userRemap : row.pB;
  if (!effectivePB) return;
  const inp = document.getElementById('bvalInput_' + idx);
  if (!inp) return;
  const newVal = inp.value.trim();

  if (newVal === '' || newVal === effectivePB.value) {
    bvalOverrides.delete(remapKey);
  } else {
    bvalOverrides.set(remapKey, newVal);
  }

  closeBvalEditor(idx);

  const tr = document.querySelector(`tr[data-idx="${idx}"]`);
  if (tr) {
    const isModified = bvalOverrides.has(remapKey);
    const displayVal = isModified ? bvalOverrides.get(remapKey) : effectivePB.value;
    const dispEl = tr.querySelector('.bval-display');
    if (dispEl) {
      const modDot = isModified ? '<span class="bval-modified-dot"></span>' : '';
      const editIcon = '<span class="bval-edit-icon">✎</span>';
      const dbEntry = PF525_DB.get(effectivePB.num);
      const unitTag = (dbEntry && dbEntry.unit && displayVal !== '—')
        ? `<span class="pval-unit">${escHtml(dbEntry.unit)}</span>` : '';
      dispEl.innerHTML = `${modDot}${escHtml(displayVal)}${unitTag}${editIcon}`;
      dispEl.className = `bval-display${isModified ? ' bval-modified' : (row.status==='diff'?' diff':'')}`;
    }
    const bvalOvrForSearch = bvalOverrides.get(remapKey) || '';
    tr.dataset.search = `${row.pA.num} ${row.pA.name} ${effectivePB.num} ${effectivePB.name} ${userNotes.get(remapKey)||''} ${row.manualNote||''} ${bvalOvrForSearch}`.toLowerCase();
  }

  if (effectivePB && row.status !== 'ro') {
    const bValEff = bvalOverrides.has(remapKey) ? bvalOverrides.get(remapKey) : effectivePB.value;
    const newStatus = normaliseVal(row.pA.value) === normaliseVal(bValEff) ? 'same' : 'diff';
    if (tr) {
      tr.dataset.status = newStatus;
      const pill = tr.querySelector('.pill');
      if (pill) {
        pill.className = `pill ${newStatus==='same'?'pill-same':'pill-diff'}`;
        pill.textContent = newStatus==='same'?'Match':'Differs';
      }
    }
  }
  filterTable();
}

