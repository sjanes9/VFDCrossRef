const HELP_B64 = "";

async function _loadHelpDB(){
  try {
    const bin = atob(HELP_B64); const bytes = new Uint8Array(bin.length);
    for (let i=0;i<bin.length;i++) bytes[i]=bin.charCodeAt(i);
    const stream = new Blob([bytes]).stream().pipeThrough(new DecompressionStream('gzip'));
    HELP_DB = JSON.parse(await new Response(stream).text());
  } catch(e){ HELP_DB = null; }
}
function detectHelpFamily(name){
  const n = (name||'').toLowerCase();
  if (/\b700\b|pf700|powerflex\s*700/.test(n)) return 'pf700';
  if (/\b52[05]\b|pf52[05]|powerflex\s*52/.test(n)) return 'pf525';
  if (/\b70\b|pf70|powerflex\s*70/.test(n)) return 'pf70';
  return '';
}
function _helpFamLabel(f){ return ({pf70:'70', pf700:'700 VC', pf525:'525'})[f] || f; }
function helpSectionHtml(pName, famHint){
  if (HELP_DB === undefined) return '<div class="dp-section-title">Parameter Help</div><div class="dp-no-data">Loading help data\u2026</div>';
  if (!HELP_DB) return '';
  const key = (pName||'').toLowerCase();
  const order = famHint ? [famHint, 'pf525', 'pf700', 'pf70'] : ['pf700','pf70','pf525'];
  let hit=null, hitFam=null;
  for (const fam of order){ const db=HELP_DB[fam]; if (db && db[key]){ hit=db[key]; hitFam=fam; break; } }
  if (!hit) return '<div class="dp-section-title">Parameter Help</div><div class="dp-no-data">No help-file entry found for \u201c'+escHtml(pName)+'\u201d.</div>';
  const titleLine = (hit.t && hit.t.toLowerCase()!==key) ? '<div style="font-weight:700;margin-bottom:3px">'+escHtml(hit.t)+'</div>' : '';
  const src = '<span style="font-size:9px;color:var(--muted);text-transform:none;letter-spacing:0;font-weight:400"> (PowerFlex '+_helpFamLabel(hitFam)+' help'+(hit.i?', param '+escHtml(hit.i):'')+')</span>';
  return '<div class="dp-section-title">Parameter Help'+src+'</div><div class="dp-desc">'+titleLine+(hit.d?escHtml(hit.d):'<span style="color:var(--muted)">(no further description)</span>')+'</div>';
}

