// ── Factory-default detection (drive-agnostic) ─────────────────────────────
// default / units / min / max come from the uploaded parameter export (parsed into
// each param's .dflt/.unit/.min/.max fields), so the "at default" flag works for ANY
// PowerFlex drive with no hardcoded table. normaliseVal() makes the comparison
// tolerant of formatting/units ("10.0" == "10" == "10.0 Hz").
function isAtDefault(p) {
  if (!p || p.value === undefined || p.value === null || p.value === '') return false;
  if (p.dflt === undefined || p.dflt === null || String(p.dflt) === '') return false;
  return normaliseVal(p.value) === normaliseVal(p.dflt);
}

// ── Migration priority (drive-agnostic, name-based auto-rating) ─────────────
// Rated from the parameter NAME so it works across PowerFlex models regardless of
// numbering. This is an editable heuristic — click any Priority cell to override.
const CRIT_ORDER = { critical: 0, important: 1, standard: 2 };
const CRIT_MONITOR_RE  = /reserved|fault\s*\d|fault\s*code|status|feedback|elapsed|\bmeter\b|display\s*param|testpoint|drive\s*temp|control\s*temp|output\s*(freq|current|voltage|power|rpm|speed)|commanded\s*freq|dc\s*bus\s*volt|kwh|mwh|energy\s*saved|\bco2\b|process\s*(display|fract)|units\s*traveled|sw\s*ver|drive\s*type|counter\s*status|timer\s*status/i;
const CRIT_CRITICAL_RE = /motor\s*np|nameplate|motor\s*(volts|hertz|hz|fla|amps|rpm|poles|power)|motor\s*ol|overload|torque\s*perf\s*mode|motor\s*cntl|control\s*mode|sensorless|vector|\bsvc\b|max(imum)?\s*(freq|speed|voltage)|min(imum)?\s*(freq|speed)|current\s*limit|shear\s*pin|stop\s*(mode|brk)|stop\/brk|start\s*source|speed\s*ref|accel\s*time|decel\s*time/i;
const CRIT_IMPORTANT_RE = /preset\s*(freq|speed)|skip\s*freq|analog\s*(in|out)|anlg\s*(in|out)|\b10v\b|4-20|digin|dig\s*in|termblk|digital\s*(in|out)|relay\s*out|opto\s*out|\bpid\b|\bjog\b|dc\s*brake|db\s*(resistor|threshold)|flying\s*start|auto\s*rstrt|auto\s*restart|start\s*at\s*power|direction\s*mode|reverse\s*disable|\bcomm\b|rs485|node\s*addr|ip\s*addr|subnet|gateway|baud|data\s*rate|ethernet|\ben\s|sleep|wake|\bpwm\b|carrier|bus\s*reg|power\s*loss|em\s*brk|purge/i;
function autoCriticality(p) {
  const n = (p && p.name) ? p.name : '';
  if (!n) return 'standard';
  if (CRIT_MONITOR_RE.test(n))  return 'standard';
  if (CRIT_CRITICAL_RE.test(n)) return 'critical';
  if (CRIT_IMPORTANT_RE.test(n)) return 'important';
  return 'standard';
}

