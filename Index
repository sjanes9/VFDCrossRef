let _remapAllParams = [];

function _rmpTokens(s){ return (s||'').toLowerCase().replace(/[^a-z0-9]+/g,' ').trim().split(/\s+/).filter(Boolean); }
function _rmpBigrams(s){ s=(s||'').toLowerCase().replace(/[^a-z0-9]/g,''); const b={}; for(let i=0;i<s.length-1;i++) b[s.slice(i,i+2)]=1; return b; }
function _rmpDice(a,b){ const A=_rmpBigrams(a),B=_rmpBigrams(b); const ak=Object.keys(A),bk=Object.keys(B); if(!ak.length||!bk.length) return 0; let inter=0; ak.forEach(x=>{if(B[x])inter++;}); return 2*inter/(ak.length+bk.length); }
function suggestBMatches(name, list, limit){
  const at=_rmpTokens(name); const scored=[];
  list.forEach(p=>{
    const bt=_rmpTokens(p.name);
    let shared=0; at.forEach(t=>{ if(bt.includes(t)) shared++; });
    const uni=new Set([...at,...bt]).size||1;
    const score = shared*2 + (shared/uni)*1.5 + _rmpDice(name,p.name)*1.5;
    if (score>0.3) scored.push({p,score});
  });
  scored.sort((a,b)=>b.score-a.score);
  return scored.slice(0, limit||6);
}
