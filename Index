}
async function iuuxExtract(bytes){
  const outer = await JSZip.loadAsync(bytes);
  const modIdx={}, dbIdx={}, dlfIdx={};
  for (const name of Object.keys(outer.files)){
    let m;
    if ((m=name.match(/ModuleConfig\/Module_(\d+)\/[^/]*\.iucx$/))) modIdx[m[1]]=name;
    else if ((m=name.match(/DatabaseData\/Database_(\d+)\/[^/]*\.iudx$/))) dbIdx[m[1]]=name;
    else if ((m=name.match(/DatabaseData\/Database_(\d+)\/.*\/L_0\.dlf$/))) dlfIdx[m[1]]=name;
  }
  // pick the drive = the database with the most parameter definitions (vs. HIM/peripheral)
  let best=null, bestCount=-1, bestDbText=null;
  for (const i of Object.keys(dbIdx)){
    const dbBytes = await outer.file(dbIdx[i]).async('uint8array');
    const dbInner = await _iuuxReadInner(dbBytes, t=>t.includes('MinMaxDflt') && t.includes('<ParamX'));
    if (!dbInner) continue;
    const count=(dbInner.text.match(/<ParamX /g)||[]).length;
    if (count>bestCount){ bestCount=count; best=i; bestDbText=dbInner.text; }
  }
  if (best===null) return null;
  const i=best;
  const defs={};
  { const body=bestDbText.split('<Data>').pop(); const re=/<ParamX ([^>]*?)\/?>/g; let m;
    while((m=re.exec(body))){ const a=_iuuxAttrs(m[1]); if(a.Num) defs[parseInt(a.Num,16)]=a; } }
  const names={}, enums={}, textToVal={}, dlfUnits={};
  if (dlfIdx[i]){
    const dlfBytes = await outer.file(dlfIdx[i]).async('uint8array');
    const dlfInner = await _iuuxReadInner(dlfBytes, t=>t.includes('<ParamX') && t.includes('Name='));
    if (dlfInner){
      const body=dlfInner.text.split('<Data>').pop();
      const re=/<ParamX ([^>]*?)(?:\/>|>([\s\S]*?)<\/ParamX>)/g; let m;
      while((m=re.exec(body))){
        const a=_iuuxAttrs(m[1]); if(!a.Num) continue; const n=parseInt(a.Num,16);
        names[n]=a.Name||('P'+n);
        if (a.Units) dlfUnits[n]=a.Units;
        const inner=m[2]||'';
        if (inner.indexOf('<Enum ')>=0){
          // Enum tags vary by drive family: DSI puts Text before Val, DPI puts Val before Text,
          // and Val is HEX in both (matching the hex parameter values). Parse order-independently.
          const em=new Map(), tv={}; const er=/<Enum ([^>]*?)\/>/g; let e;
          while((e=er.exec(inner))){
            const ea=_iuuxAttrs(e[1]);
            if (ea.Val===undefined || ea.Text===undefined) continue;
            const v=parseInt(ea.Val,16);
            if (!isNaN(v)){ em.set(v, ea.Text); tv[ea.Text]=v; }
          }
          enums[n]=em; textToVal[n]=tv;
        }
      }
    }
  }
  const modBytes = await outer.file(modIdx[i]).async('uint8array');
  const modInner = await _iuuxReadInner(modBytes, t=>/<ParamX Num="[0-9A-Fa-f]+" Value=/.test(t));
  const vals={};
  if (modInner){ const re=/<ParamX Num="([0-9A-Fa-f]+)" Value="([0-9A-Fa-f]+)"/g; let m;
    while((m=re.exec(modInner.text))) vals[parseInt(m[1],16)]=_iuuxS32(m[2]); }
  let driveName='';
  const nameInner = await _iuuxReadInner(modBytes, t=>t.includes('NameDescription'));
  if (nameInner){ const nm=nameInner.text.match(/<Name>([^<]*)<\/Name>/) || nameInner.text.match(/<n>([^<]*)<\/n>/); if(nm) driveName=nm[1]; }
  if (!driveName){ try { const hdr=(await outer.file('_Header.xml').async('string')).replace(/\u0000/g,''); const am=hdr.match(/<AppName>([^<]*)<\/AppName>/); if(am) driveName=am[1]; } catch(e){} }
  const params=new Map(); const scaleByNum={};
  for (const numStr of Object.keys(defs)){
    const num=+numStr; const a=defs[num];
    if (!(num in names)) continue;
    const div=_iuuxScaleDiv(a); scaleByNum[num]=div;
    const em=enums[num];
    const mmd=(a.MinMaxDflt||'0,0,0').split(',');
    const minR=_iuuxS32(mmd[0]), maxR=_iuuxS32(mmd[1]), dfltR=_iuuxS32(mmd[2]);
    const raw=(num in vals)?vals[num]:dfltR;
    const dec=String(div).length-1;
    const entry={
      num, name:names[num],
      value:_iuuxRawToDisplay(raw,div,em),
      dflt:_iuuxRawToDisplay(dfltR,div,em),
      min: div>1?(minR/div).toFixed(dec):String(minR),
      max: div>1?(maxR/div).toFixed(dec):String(maxR),
