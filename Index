    const verified = isVerified(row) ? 'Yes' : 'No';
    const flagged  = isFlagged(row) ? 'Yes' : 'No';
    const atDef    = isAtDefault(pA) ? 'Yes' : 'No';
    const critC    = effectiveCrit(row); const critCap = critC.charAt(0).toUpperCase() + critC.slice(1);
    const q = s => '"' + String(s||'').replace(/"/g,'""') + '"';
    lines.push([
      q(critCap),
      q('P'+pA.num), q(pA.name), q(pA.value), q(atDef),
      q(pB ? 'P'+pB.num : ''), q(pB ? pB.name : ''), q(pB ? pB.value : ''),
      q(bvalEffective), q(status), q(manualNote), q(userNote), q(flagged), q(verified)
    ].join(','));
  });
  const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.href = url; a.download = `VFD_Comparison_${nameA.replace(/\s+/g,'_')}_to_${nameB.replace(/\s+/g,'_')}.csv`;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
}

