// NAMES + enum option text in the .dlf language files. It's fully self-describing,
// so this works for any PowerFlex drive with no built-in tables. Export rewrites only
// edited values and repackages, leaving every other file intact.
const _iuuxAttrs = tag => { const o={}; const re=/(\w+)="([^"]*)"/g; let m; while((m=re.exec(tag))) o[m[1]]=m[2]; return o; };
const _iuuxScaleDiv = a => {
  if (a.Scale){ const d=parseInt(a.Scale.split(',')[2],16); return d||1; }        // DSI: explicit divisor
  if (a.Desc){ const dec=(parseInt(a.Desc,16)>>12)&0xF; return Math.pow(10,dec); } // DPI: decimals = Desc bits 12-15
  return 1;
};
const _iuuxS32 = h => { const v=parseInt(h||'0',16); return isNaN(v)?0:(v>=0x80000000 ? v-0x100000000 : v); };
function _iuuxRawToDisplay(raw, div, enumMap){
  if (enumMap && enumMap.has(raw)) return enumMap.get(raw);
  if (div>1){ const dec=String(div).length-1; return (raw/div).toFixed(dec); }
  return String(raw);
}
function _iuuxDisplayToRaw(disp, div, textToVal){
  if (textToVal){
    if (typeof textToVal.get === 'function'){ if (textToVal.has(disp)) return textToVal.get(disp); }
    else if (textToVal[disp] !== undefined) return textToVal[disp];
  }
